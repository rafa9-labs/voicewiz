# VoiceWiz — local-only configuration
# Copy to .env and customize if needed
#
# CUDA is auto-detected — just download the binary:
#   npm run download:cuda-whisper
#
# To force-disable GPU: uncomment below
# WHISPER_CUDA_ENABLED=false
#
# GPU device index (if you have multiple GPUs):
# TRANSCRIPTION_GPU_INDEX=0
# INTELLIGENCE_GPU_INDEX=0
#
# Log level (debug | info | warn | error):
# OPENWHISPR_LOG_LEVEL=info
